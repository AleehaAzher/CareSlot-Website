    <script>
        $(document).ready(function() {
       
            $("#Logout").click(function (event) {
            event.preventDefault();
            $("#logoutModal").modal('show');
        });

        $("#confirmLogout").click(function () {
            window.location.href = "/User/Logout";
        });

        $.ajax({
            type:'Get',
            url:'/Home/currentRole',
            dataType:'json',
            success:function(response){
                $("#currentRole").text(response.role);
            },
            error:function(error)
            {
                alert("Error fetching current role");
            }
        });
            $.ajax({
               type:'Get',
               url:'/Home/currentName',
               dataType:'json',
               success:function(response){
                   $("#currentName").text(response.name);
               },
               error:function(error)
               {
                   alert("Error fetching current name");
               }
            });
         
            $.ajax({
            type: 'GET',
            url: '/Navbar/GetProfileImage',
            dataType: 'json',
            success: function (response) {
                if (response.img) {
                    $(".navbar .avatar img").attr("src", response.img);
                }
            },
            error: function () {
                console.error("Error fetching profile image.");
            } 
            });

          $.ajax({
              type:'get',
              url:'/Doctor/getAppointmentRequestCount',
              dataType:'json',
              success:function(response){
                  $("#doctorRequestCount").text(response.count);
              },
              error:function(){
                  showToast("error","Error getting doctor's appointments' count");
              }
              });

                  $.ajax({
                 type:'get',
                 url:'/Patient/getMyAppointmentCount',
                 dataType:'json',
                 success:function(response){
                        $("#patientMyAppointmentCount").text(response.count);
                 },
                 error:function(){
                     showToast("error","Error getting doctor's appointments' count");
                 }
               });
                       $(function () {
                      let current = window.location.pathname.toLowerCase();
                      $(".menu-item a").each(function () {
                    if (this.getAttribute("href").toLowerCase() === current) {
                      $(this).parent().addClass("active");
                    }
                  });
                });
             });
         
           window.showToast = function(type, message, onDismiss) {
            const toastBox = document.getElementById("toastBox");
            if (!toastBox) return;

            const toast = document.createElement("div");
            toast.className = `my-toast ${type}`;

            let icon = "";
            if (type === "success") icon = "fa-circle-check";
            else if (type === "error") icon = "fa-circle-xmark";
            else if (type === "warning") icon = "fa-triangle-exclamation";
            else icon = "fa-circle-info";

            toast.innerHTML = `
                <i class="fa-solid ${icon}"></i>
                <span style="flex:1">${message}</span>
                <button class="close-btn" aria-label="Close">&times;</button>
                <div class="progress"></div>
            `;

            toastBox.appendChild(toast);
            setTimeout(() => toast.classList.add("show"), 50);

            const removeToast = () => {
                if (toast.parentNode) {
                    toast.remove();
                    if (typeof onDismiss === "function") onDismiss(); 
                }
            };

            toast.querySelector(".close-btn").addEventListener("click", removeToast);

            setTimeout(() => {
                const bar = toast.querySelector(".progress");
                if (bar) bar.style.width = "0%";
            }, 100);

            setTimeout(removeToast, 3200);
        };

          
    </script>

