    @*         </div>
            <!-- /Layout page -->
        </div>

        <!-- Overlay -->
        <div class="layout-overlay layout-menu-toggle"></div>
    </div> *@

    <div id="toastBox"></div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="../assets/vendor/js/bootstrap.js"></script>
    <script src="../assets/vendor/js/menu.js"></script>
    <script src="../assets/js/main.js"></script>

    <!-- Vendors JS -->
    <script src="../assets/vendor/libs/apex-charts/apexcharts.js"></script>

    <!-- Page JS -->
    <script src="../assets/js/dashboards-analytics.js"></script>

    <!-- Github button -->
    <script async defer src="https://buttons.github.io/buttons.js"></script>

    <!-- Sidebar toggle -->
    <script>
           $(document).ready(function() {
              

                        $("#Logout").click(function (event) {
               event.preventDefault();
               $("#logoutModal").modal('show');
           });

           $("#confirmLogout").click(function () {
               window.location.href = "/User/Logout";
           });

           $.ajax({
               type:'Get',
               url:'/Home/currentRole',
               dataType:'json',
               success:function(response){
                   $("#currentRole").text(response.role);
               },
               error:function(error)
               {
                   alert("Error fetching current role");
               }
           });
               $.ajax({
                  type:'Get',
                  url:'/Home/currentName',
                  dataType:'json',
                  success:function(response){
                      $("#currentName").text(response.name);
                  },
                  error:function(error)
                  {
                      alert("Error fetching current name");
                  }
              });


               $.ajax({
               type: 'GET',
               url: '/Navbar/GetProfileImage',
               dataType: 'json',
               success: function (response) {
                   if (response.img) {
                       $(".navbar .avatar img").attr("src", response.img);
                   }
               },
               error: function () {
                   console.error("Error fetching profile image.");
               }
           });


        });

              



    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
