                                    <li><div class="dropdown-divider my-1"></div></li>
                                    <li>
                                        <a class="dropdown-item" href="/Navbar/DoctorProfile" id="myProfile"><i class="icon-base bx bx-user icon-md me-3"></i><span>My Profile</span></a>
                                    </li>
                                   
