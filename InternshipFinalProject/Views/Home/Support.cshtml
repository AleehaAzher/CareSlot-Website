@{
    ViewData["Title"] = "Support";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark">Support</h2>
        <p class="lead text-muted w-75 mx-auto">
            Need help? We’re here to guide you. Explore common questions or reach out to us directly.
        </p>
    </div>

    <section class="py-4 border-bottom">
        <h4 class="fw-semibold text-dark mb-4">Frequently Asked Questions</h4>
        <div class="mb-3">
            <h6 class="fw-semibold">How do I reset my password?</h6>
            <p class="text-muted">
                You can reset your password by clicking on “Forgot Password” at the login page.
                A secure reset link will be sent to your registered email.
            </p>
        </div>
        <div class="mb-3">
            <h6 class="fw-semibold">How do I book an appointment?</h6>
            <p class="text-muted">
                Log in to your account, search for a doctor, and choose an available slot.
                Confirm your appointment with a single click.
            </p>
        </div>
        <div class="mb-3">
            <h6 class="fw-semibold">Is my data secure?</h6>
            <p class="text-muted">
                Yes, your data is encrypted and protected with the latest security practices.
                We take privacy and security very seriously.
            </p>
        </div>
    </section>

    <section class="py-4">
        <h4 class="fw-semibold text-dark mb-3">Still need help?</h4>
        <p class="text-muted">
            If your issue isn’t listed above, please contact our support team. We aim to respond within 24 hours.
        </p>

        <ul class="list-unstyled">
            <li class="mb-2">
                <i class="bi bi-envelope-fill text-primary me-2"></i>
                support@careslot.com
            </li>
            <li class="mb-2">
                <i class="bi bi-telephone-fill text-primary me-2"></i>
                +1 (800) 123-4567
            </li>
            <li>
                <i class="bi bi-chat-dots-fill text-primary me-2"></i>
                Live chat available Mon–Sat, 9:00 AM – 6:00 PM
            </li>
        </ul>
    </section>

</div>
