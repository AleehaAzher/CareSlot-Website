@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_PublicLayout.cshtml"; 
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold">About <span class="text-primary">Our Platform</span></h1>
        <p class="text-muted fs-5">Making healthcare simple, accessible, and reliable for everyone</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-bullseye text-primary me-2"></i>Our Mission</h4>
                    <p class="text-muted">
                        To bridge the gap between patients and doctors by providing a seamless online
                        appointment system, ensuring that quality healthcare is just a few clicks away.
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm h-100 rounded-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-lightbulb text-warning me-2"></i>Our Vision</h4>
                    <p class="text-muted">
                        To become a trusted healthcare companion that empowers individuals to take
                        control of their health using technology-driven solutions.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <h2 class="fw-bold text-center mb-4">Why Choose Us?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center rounded-4 p-4">
                    <i class="bi bi-calendar-check fs-1 text-primary mb-3"></i>
                    <h5 class="fw-bold">Convenient Booking</h5>
                    <p class="text-muted">Easily schedule appointments anytime, anywhere, without waiting in long queues.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center rounded-4 p-4">
                    <i class="bi bi-person-vcard fs-1 text-success mb-3"></i>
                    <h5 class="fw-bold">Trusted Professionals</h5>
                    <p class="text-muted">Connect with experienced and qualified healthcare providers across specialties.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center rounded-4 p-4">
                    <i class="bi bi-shield-lock fs-1 text-warning mb-3"></i>
                    <h5 class="fw-bold">Secure Platform</h5>
                    <p class="text-muted">Your data and health information are handled with top-level security and privacy.</p>
                </div>
            </div>
        </div>
    </div>

    <div>
        <h2 class="fw-bold text-center mb-4">Our Values</h2>
        <div class="row g-4 justify-content-center">
            <div class="col-md-3 text-center">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <i class="bi bi-heart-pulse fs-1 text-danger mb-3"></i>
                        <h6 class="fw-bold mb-2">Compassion</h6>
                        <p class="text-muted small">We believe in patient-first care with empathy and understanding.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <i class="bi bi-lightning-charge fs-1 text-primary mb-3"></i>
                        <h6 class="fw-bold mb-2">Innovation</h6>
                        <p class="text-muted small">We use modern technology to create efficient and reliable healthcare solutions.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3 text-center">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-body p-4">
                        <i class="bi bi-people fs-1 text-success mb-3"></i>
                        <h6 class="fw-bold mb-2">Community</h6>
                        <p class="text-muted small">We are committed to improving healthcare access for all communities.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
