    $(document).ready(function(){
        var id='@ViewBag.userid';
    $.ajax({
            type:'get',
            url:'/Appointment/PatientAppointmentCount',
            data:{id:id},
            dataType:'json',
            success:function(response){
                if(response.success)
                {
                    $("#upcomingAppointments").text(response.confirmed);
                   $("#completedAppointments").text(response.completed);
                }
            },
            error:function()
            {
                alert("Error getting appointments count");
            }
        });
            $.ajax({
            type:'get',
            url:'/Prescription/PatientPrescriptionCount',
            data:{id:id},
            dataType:'json',
            success:function(response){
                if(response.success)
                {
                    $("#prescriptionCount").text(response.count);
                }
            },
            error:function()
            {
                alert("Error getting prescription count");
            }
        });
    });
</script>
