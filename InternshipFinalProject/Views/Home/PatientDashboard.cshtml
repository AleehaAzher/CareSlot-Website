@{
    ViewData["Title"] = "Patient Dashboard";
}

<div class="container-fluid py-4">

    <div class="mb-4">
        <h3 class="fw-bold">Welcome back, @ViewBag.name</h3>
        <p class="text-muted">Here’s an overview of your health and appointments.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h6 class="text-muted text-nowrap">Upcoming Appointments</h6>
                    <h3 class="fw-bold" id="upcomingAppointments"></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h6 class="text-muted">Completed Visits</h6>
                    <h3 class="fw-bold" id="completedAppointments"></h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h6 class="text-muted">Prescriptions</h6>
                    <h3 class="fw-bold" id="prescriptionCount"></h3>
                    @* <small class="text-warning"><i class="bi bi-capsule"></i> Active</small> *@
                </div>
            </div>
        </div>
        
    </div>

