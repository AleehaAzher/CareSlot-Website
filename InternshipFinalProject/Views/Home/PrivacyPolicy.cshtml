@{
    ViewData["Title"] = "Privacy Policy";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="container my-5">
    <div class="text-center mb-5">
        <h2 class="fw-semibold text-dark">Privacy Policy</h2>
        <p class="text-muted">Your trust is important to us. Please read carefully how we handle your data.</p>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="fw-semibold text-dark">1. Information We Collect</h5>
            <p class="text-muted mb-0">
                We may collect personal information such as your name, email address, and health-related details
                when you use our services. This information is used solely to provide and improve your healthcare experience.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="fw-semibold text-dark">2. How We Use Your Information</h5>
            <p class="text-muted mb-0">
                Your data is used to manage appointments, communicate updates, and ensure the smooth functioning
                of our platform. We do not share your information with third parties without your consent.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="fw-semibold text-dark">3. Data Security</h5>
            <p class="text-muted mb-0">
                We implement industry-standard security measures to protect your personal information.
                However, please note that no method of transmission over the internet is 100% secure.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h5 class="fw-semibold text-dark">4. Your Rights</h5>
            <p class="text-muted mb-0">
                You have the right to access, update, or request deletion of your personal data.
                If you have any concerns, please contact our support team.
            </p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h5 class="fw-semibold text-dark">5. Updates to this Policy</h5>
            <p class="text-muted mb-0">
                We may update this Privacy Policy from time to time. Changes will be posted on this page
                and will take effect immediately upon publication.
            </p>
        </div>
    </div>

    <div class="text-center mt-5">
        <p class="text-muted mb-1">If you have questions about our Privacy Policy, please reach out to us.</p>
        <a href="/Home/Support" class="btn btn-outline-primary px-4">Contact Us</a>
    </div>
</div>
