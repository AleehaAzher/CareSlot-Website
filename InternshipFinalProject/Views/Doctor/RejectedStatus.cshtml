@{
    Layout = "~/Views/Shared/_RestrictedLayout.cshtml";
    ViewData["Title"] = "Profile Rejected";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white text-center rounded-top-4">
                    <h3 class="mb-0">Profile Rejected</h3>
                </div>
                <div class="card-body text-center p-5">
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                    <h4 class="mt-4">Your Profile Has Been Rejected</h4>
                    <p class="text-muted mt-3">
                        Unfortunately, your doctor profile did not meet our approval requirements.
                        Please contact support or wait for further instructions from the administration.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
