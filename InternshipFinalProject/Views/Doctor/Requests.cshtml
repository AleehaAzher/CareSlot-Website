@model IEnumerable<InternshipFinalProject_Core.Models.AppointmentModel>
@{
    ViewData["Title"] = "Requests";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-12">
            <h4 class="fw-bold mb-3">Appointment Requests</h4>

            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="card shadow-sm border-0 rounded-4 mb-3">
                        <div class="card-body row align-items-center">

                            <div class="col-md-1 text-center">
                                @if (!string.IsNullOrEmpty(item.Patient.img))
                                {
                                    <img src="@item.Patient.img" class="rounded-circle" alt="patient" width="60" height="60" />
                                }
                                else
                                {
                                    <img src="../assets/img/avatars/defaultAvatar.jpg" class="rounded-circle" alt="patient" width="60" height="60" />
                                }
                            </div>

                            <div class="col-md-2">
                                <h6 class="fw-bold mb-1">@item.Patient.User.FullName</h6>
                            </div>

                            <div class="col-md-3">
                                <small class="text-muted d-block">
                                    <i class="bi bi-clock me-1"></i>
                                    @item.Date?.ToString("MMM dd, yyyy - hh:mm tt")
                                </small>
                                <h6 class="mb-0">@item.Notes</h6>
                            </div>

                            <div class="col-md-3">
                                <h6 class="text-gray mb-1">Type of Appointment</h6>
                                <span class="badge bg-light text-primary border rounded-pill">
                                    @if (item.AppointmentType == "Video Call")
                                    {
                                        <i class="bi bi-camera-video-fill me-1"></i> 
                                        @item.AppointmentType
                                    }
                                    else if (item.AppointmentType == "Direct Visit")
                                    {
                                        <i class="bi bi-hospital me-1"></i> 
                                        @item.AppointmentType
                                    }
                                    else
                                    {
                                        <i class="bi bi-telephone-fill me-1"></i> 
                                        @item.AppointmentType
                                    }
                                </span>
                            </div>

                            <div class="col-md-3 text-end">
                                <button class="btn btn-outline-success btn-sm me-2 acceptRequest"
                                        data-id="@item.AppointmentId">
                                    <i class="bi bi-check-circle me-1"></i> Accept
                                </button>

                                <button class="btn btn-outline-danger btn-sm rejectRequest"
                                        data-id="@item.AppointmentId">
                                    <i class="bi bi-x-circle me-1"></i> Reject
                                </button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info">No appointment requests found.</div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="acceptModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Acceptance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to accept this appointment?
                <input type="hidden" id="acceptAppointmentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-success" id="confirmAccept">Yes, Accept</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-3">
            <div class="modal-header">
                <h5 class="modal-title">Reject Appointment</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Reason for rejection</label>
                <textarea class="form-control" id="rejectReason" rows="3" placeholder="Enter reason"></textarea>
                <input type="hidden" id="rejectAppointmentId" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmReject">Submit Rejection</button>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {
        $(".acceptRequest").click(function () {
            var id = $(this).data("id");
            $("#acceptAppointmentId").val(id);
            $("#acceptModal").modal("show");
        });

        $("#confirmAccept").click(function () {
            var id = $("#acceptAppointmentId").val();
            var data={
                id:id,
                reason:null,
                status:"Confirmed" || null
            }
            $.ajax({
                type: "POST",
                url: "/Appointment/UpdateStatus",
                contentType:"application/json; charset=utf-8",
                data: JSON.stringify(data),
                success: function (response) {
                    $("#acceptModal").modal("hide");
                    showToast("success", "Appointment accepted successfully.");
                    location.reload();
                },
                error: function () {
                    showToast("error", "Error accepting appointment.");
                }
            });
        });

        $(".rejectRequest").click(function () {
            var id = $(this).data("id");
            $("#rejectAppointmentId").val(id);
            $("#rejectReason").val("");
            $("#rejectModal").modal("show");
        });

        $("#confirmReject").click(function () {
            var id = $("#rejectAppointmentId").val();
            var reason = $("#rejectReason").val();
            if (!reason.trim()) {
                alert("Please provide a reason before rejecting.");
                return;
            }
            var data={
                id:id,
                status:"Cancelled" || null,
                reason: reason || null
            };

            $.ajax({
                type: "POST",
                url: "/Appointment/UpdateStatus",
                                contentType:"application/json; charset=utf-8",
                data: JSON.stringify(data),
                success: function (response) {
                    $("#rejectModal").modal("hide");
                    showToast("success", "Appointment rejected successfully.");
                    location.reload();
                },
                error: function () {
                    showToast("error", "Error rejecting appointment.");
                }
            });
        });
    });
</script>
