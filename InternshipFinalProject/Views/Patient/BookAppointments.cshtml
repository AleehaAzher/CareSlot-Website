@model IEnumerable<InternshipFinalProject_Core.Models.DoctorModel>
@{
    ViewData["Title"] = "Book Appointment";
}
<div class="container-fluid py-4">
    <h4 class="fw-bold mb-2">Search Doctors</h4>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <select class="form-select" id="filterSpecialization">
                        <option value="" selected>--Specialization--</option>
                        <option>Cardiology</option>
                        <option>Dermatology</option>
                        <option>Neurology</option>
                        <option>Orthopedics</option>
                        <option>Pediatrics</option>
                        <option>Psychiatry</option>
                        <option>General Medicine</option>
                    </select>
                </div>
                <div class="col-md-4">

                    <select class="form-select" id="filterDays">
                        <option value="" selected>--Availability by Day--</option>
                        <option value="Mon">Monday</option>
                        <option value="Tues">Tuesday</option>
                        <option value="Wed">Wednesday</option>
                        <option value="Thurs">Thursday</option>
                        <option value="Fri">Friday</option>
                        <option value="Sat">Saturday</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <input type="number" class="form-control" placeholder="Max Fees (e.g. 100) " id="filterFees" />
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex justify-content-end mb-4">
        <button class="btn btn-outline-secondary me-2" id="resetFilters" type="submit">Reset</button>
        <button class="btn btn-info" id="saveFilters" type="submit">Apply</button>
    </div>
    <div class="row g-3" id="doctorListBody">
        <partial name="BookAppointmentListPartialView" model= "Model" />
    </div>

    <div class="modal fade" id="bookAppointmentModal" tabindex="-1" aria-labelledby="bookAppointmentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content rounded-4 shadow">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="bookAppointmentModalLabel">Book Appointment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="appointmentForm">
                        <div class="row g-3">
                            <input type="hidden" id="doctorId" />

                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="modalDoctorName">Doctor Name</label>
                                <input type="text" class="form-control" readonly id="modalDoctorName" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="modalSpecialization">Department</label>
                                <input type="text" class="form-control" readonly id="modalSpecialization" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Patient Name</label>
                                <input type="text" class="form-control" placeholder="Enter patient name" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Appointment Mode</label>
                                <select class="form-select" id="mode">
                                    <option selected>--Select Mode--</option>
                                    <option>Audio Call</option>
                                    <option>Video Call</option>
                                    <option>Direct Visit</option>

                                </select>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Appointment Date & Time</label>
                                <input type="datetime-local" class="form-control" id="appointmentDateTime" />
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-semibold">Notes</label>
                                <textarea class="form-control" rows="3" placeholder="Enter any additional notes or symptoms" id="notes"></textarea>
                            </div>
                        </div>
                    </form>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="appointmentForm" class="btn btn-primary">Confirm Appointment</button>
                </div>


                
            </div>
        </div>
     </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function(){
          $("#saveFilters").on("click",function(event){
            event.preventDefault();

    var changes = {
        Specialization: $("#filterSpecialization").val() || null,
        Day:  $("#filterDays").val() || null,
        Fees:$("#filterFees").val() ||null
    };

            $.ajax({
                type:'POST',
                url:'/Patient/BookAppointmentApplyFilters',
                data: JSON.stringify(changes),
                contentType: "application/json; charset=utf-8",
                success: function (partialViewHtml) {
                    $("#doctorListBody").html(partialViewHtml);
                },
                error: function () {
                    alert("Something went wrong while filtering.");
                }
            });
        });
         $("#resetFilters").on("click",function(event){
            event.preventDefault();

            $("#filterSpecialization").val("");
            $("#filterDays").val("");
            $("#filterFees").val("");

            var changes={
                Specialization: null,
                Day:null,
                Fees: null
            };

            $.ajax({
                type:'POST',
                url:'/Patient/BookAppointmentApplyFilters',
                data: JSON.stringify(changes),
                contentType: "application/json; charset=utf-8",
                success: function (partialViewHtml) {
                    $("#doctorListBody").html(partialViewHtml);
                },
                error: function () {
                    alert("Something went wrong while filtering.");
                }
            });
        });


           $(document).ready(function () {

    $(document).on("click", ".bookBtn", function (event) {
        event.preventDefault();
            var card = $(this).closest(".card");
            var doctorId = $(this).data("doctorid");
            var fullName = card.find(".doctorName").data("doctorname");
            var specialization = card.find(".specialization").data("specialization");

            $("#doctorId").val(doctorId); 
            $("#modalDoctorName").val("Dr. " + fullName);
            $("#modalSpecialization").val(specialization);

            $("#bookAppointmentModal").modal("show");
        });

        $("#appointmentForm").on("submit", function (event) {
            event.preventDefault();

            var formData = {
                DoctorId: parseInt($("#doctorId").val()),
                PatientId: '@ViewBag.userid',
                Date: $("#appointmentDateTime").val() || null,
                Notes: $("#notes").val(),
                AppointmentType: $("#mode").val()
            };

            $.ajax({
                type: 'POST',
                url: '/Appointment/Create',
                data: JSON.stringify(formData),
                contentType: "application/json; charset=utf-8",
                success: function (res) {
                    if (res.success) {
                        $("#bookAppointmentModal").modal("hide");
                        showToast("success", res.message || "Appointment created successfully.", function () {
                            location.reload();
                        });
                    } else {
                        showToast("error", res.message || "Appointment creation failed.");
                    }
                },
                error: function () {
                    showToast("error", "Error saving appointment.");
                }
            });
        });

    });

    });
</script>


