@{
    ViewData["Title"] = "My Favourite Doctors";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h4 class="fw-bold">My Favourite Doctors</h4>
            <p class="text-muted">Here are the doctors you’ve added to your favourites for quick access.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <img src="../assets/img/avatars/defaultAvatar.jpg"
                         class="rounded-circle mb-3" alt="Doctor" width="90" height="90">

                    <h5 class="fw-bold mb-1">Dr. Adrian Payal</h5>
                    <p class="text-muted mb-2">Cardiologist</p>
                    <p class="small text-muted mb-3"><i class="bi bi-geo-alt-fill me-1"></i> Lahore, Pakistan</p>

                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-outline-info btn-sm">
                            <i class="bi bi-info-circle me-1"></i> View
                        </button>
                        <button class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-calendar-plus me-1"></i> Book
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <img src="../assets/img/avatars/defaultAvatar.jpg"
                         class="rounded-circle mb-3" alt="Doctor" width="90" height="90">
                    <h5 class="fw-bold mb-1">Dr. Mary Jane</h5>
                    <p class="text-muted mb-2">Dentist</p>
                    <p class="small text-muted mb-3"><i class="bi bi-geo-alt-fill me-1"></i> Karachi, Pakistan</p>

                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-outline-info btn-sm">
                            <i class="bi bi-info-circle me-1"></i> View
                        </button>
                        <button class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-calendar-plus me-1"></i> Book
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-body text-center p-4">
                    <img src="../assets/img/avatars/defaultAvatar.jpg"
                         class="rounded-circle mb-3" alt="Doctor" width="90" height="90">

                    <h5 class="fw-bold mb-1">Dr. John Doe</h5>
                    <p class="text-muted mb-2">Dermatologist</p>
                    <p class="small text-muted mb-3"><i class="bi bi-geo-alt-fill me-1"></i> Islamabad, Pakistan</p>

                    <div class="d-flex justify-content-center gap-2">
                        <button class="btn btn-outline-info btn-sm">
                            <i class="bi bi-info-circle me-1"></i> View
                        </button>
                        <button class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-calendar-plus me-1"></i> Book
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
